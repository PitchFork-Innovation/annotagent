# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/annotagent

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-32+-char-random-string
NEXTAUTH_URL=http://localhost:3000

# ── AWS S3 (PDF storage + signed uploads) ─────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=annotagent-papers

# ── Resend (password reset emails) ────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=noreply@example.com

# ── Python ingestion service ──────────────────────────────────────────────────
# In production this points at a separately-hosted FastAPI service (Render/Fly/etc).
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_SHARED_SECRET=replace-with-shared-secret
PYTHON_INGEST_TIMEOUT_MS=900000

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
# Optional model overrides (consumed by python_service/main.py)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_ANNOTATION_MODELS=gpt-4o-mini
# OPENAI_ANNOTATION_TIMEOUT_SECONDS=120
